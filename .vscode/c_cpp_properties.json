{
  "version": 4,
  "configurations": [
    {
      "name": "Linux",
      "compileCommands": "${workspaceFolder}/build-cmake/compile_commands.json",
      "includePath": [
        "${workspaceFolder}/include",
        "${workspaceFolder}/src"
      ],
      "defines": [
        "KEYAWARE_ALWAYS_DUMP_LOGICAL_GRAPH=1",
        "KEYAWARE_ALWAYS_DUMP_RUNTIME_PLAN=1"
      ],
      "compilerPath": "/usr/bin/c++",
      "intelliSenseMode": "linux-gcc-x64",
      "cppStandard": "c++17"
    },
    {
      "name": "macOS",
      "compileCommands": "${workspaceFolder}/build-cmake-mac/compile_commands.json",
      "includePath": [
        "${workspaceFolder}/include",
        "${workspaceFolder}/src"
      ],
      "defines": [
        "KEYAWARE_ALWAYS_DUMP_LOGICAL_GRAPH=1",
        "KEYAWARE_ALWAYS_DUMP_RUNTIME_PLAN=1"
      ],
      "compilerPath": "/usr/bin/clang++",
      "intelliSenseMode": "macos-clang-arm64",
      "cppStandard": "c++17"
    }
  ]
}
