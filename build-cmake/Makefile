src/sim/simulator.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/keyaware_core.dir/build.make CMakeFiles/keyaware_core.dir/src/sim/simulator.cpp.i
.PHONY : src/sim/simulator.cpp.i

src/sim/simulator.s: src/sim/simulator.cpp.s
.PHONY : src/sim/simulator.s

# target to generate assembly for a file
src/sim/simulator.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/keyaware_core.dir/build.make CMakeFiles/keyaware_core.dir/src/sim/simulator.cpp.s
.PHONY : src/sim/simulator.cpp.s

